FROM python:3.11-slim

# ── System packages ────────────────────────────────────────────────────────────
# nodejs/npm: MCP tools (context7, playwright-mcp) via npx
# cargo/rust: cargo-based tools (rtk)
# curl: install scripts
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    nodejs \
    npm \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Rust (cargo) — non-interactive, minimal profile
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

# ── Install cc-manager ─────────────────────────────────────────────────────────
WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir -e ".[dev]"
# anyio is needed by pytest-asyncio when running Textual pilot tests
RUN pip install --no-cache-dir anyio pytest-asyncio

# ── Bootstrap a minimal Claude Code environment ───────────────────────────────
# ccm reads ~/.claude/settings.json on every run; create a clean default.
RUN mkdir -p /root/.claude /root/.cc-manager/registry \
             /root/.cc-manager/store /root/.cc-manager/backups \
             /root/.cc-manager/state
RUN echo '{"version":"1.0.0","mcpServers":{},"hooks":{}}' \
    > /root/.claude/settings.json

# Make scripts executable
RUN chmod +x /app/scripts/integration_test.sh /app/scripts/fake_claude.sh

# ── Entry point ────────────────────────────────────────────────────────────────
CMD ["bash", "/app/scripts/integration_test.sh"]
